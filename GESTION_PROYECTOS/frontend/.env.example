# Copiar a .env.development y ajustar si el backend local no usa el puerto 3030.
VITE_API_PROXY_TARGET=http://127.0.0.1:3030

# Producción (frontend en dominio distinto al backend)
# Copiar a .env.production o definir en el proveedor de hosting.
VITE_API_BASE_URL=https://gestion-proyectos-backend-v2-818499958988.us-central1.run.app
