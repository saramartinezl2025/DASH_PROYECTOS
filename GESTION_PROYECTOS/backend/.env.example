PORT=3030

# Sin PostgreSQL: tablero solo con mocks (no intenta conectar).
# API_OFFLINE_DEMO=true
#
# Intenta PostgreSQL; si falla por red (ETIMEDOUT, ECONNREFUSED), sirve mocks y cabecera X-Gestion-API-Demo.
# Util en local sin IP autorizada en Cloud SQL. En produccion suele ser false.
# API_DEMO_ON_DB_FAILURE=true

# --- Estilo GCP / Cloud SQL (recomendado si copias variables desde consola) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=inventario
DB_USER=tu_usuario
# Si la clave tiene comilla doble interior, usa comillas simples (dotenv):
# DB_PASSWORD='tu_clave_con_"_interior'
DB_PASSWORD=

# Cloud SQL suele exigir TLS desde fuera de la VPC; prueba con true si falla la conexión:
DB_SSL=true
# Si falla con "self-signed certificate" o similar, prueba false (solo dev):
DB_SSL_REJECT_UNAUTHORIZED=false

# Tiempo máx. (ms) para abrir conexión TCP/SSL hacia PostgreSQL (Cloud SQL a veces tarda >15s)
# DB_CONNECT_TIMEOUT_MS=60000
# DB_IDLE_TIMEOUT_MS=30000
# Tiempo máx. (ms) que el servidor HTTP espera la respuesta de un handler (consultas pesadas)
# HTTP_SERVER_TIMEOUT_MS=120000
# Tiempo máx. (ms) para SELECT 1 en /health (si no, el navegador puede quedarse colgado)
# HEALTH_DB_TIMEOUT_MS=8000
# /health con BD caida: por defecto HTTP 200 + { ok: false } (legible en el navegador). Para 503: /health?strict=1
# HEALTH_HTTP_STRICT=true

# --- Estilo libpq (alternativo) ---
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=inventario
# PGUSER=tu_usuario
# PGPASSWORD=
# PGSSLMODE=require
