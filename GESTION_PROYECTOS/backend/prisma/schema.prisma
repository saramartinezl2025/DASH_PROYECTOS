generator client {
  provider      = "prisma-client-js"
  // node:20-slim (Debian bookworm) usa OpenSSL 3; sin esto Prisma puede cargar el motor 1.1.x y falla con libssl.so.1.1.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}
